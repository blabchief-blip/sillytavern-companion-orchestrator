{
  "3": {
    "inputs": {
      "seed": "*seed*",
      "steps": "*steps*",
      "cfg": "*cfg*",
      "sampler_name": "*sampler*",
      "scheduler": "karras",
      "denoise": "*denoise*",
      "model": ["38", 0],
      "positive": ["6", 0],
      "negative": ["7", 0],
      "latent_image": ["5", 0]
    },
    "class_type": "KSampler",
    "_meta": {"title": "KSampler"}
  },
  "4": {
    "inputs": {"ckpt_name": "*model*"},
    "class_type": "CheckpointLoaderSimple",
    "_meta": {"title": "Kontrol Noktası Yükle"}
  },
  "5": {
    "inputs": {"width": "*width*", "height": "*height*", "batch_size": 1},
    "class_type": "EmptyLatentImage",
    "_meta": {"title": "Boş Gizli Görüntü"}
  },
  "6": {
    "inputs": {"text": "*input*", "clip": ["38", 1]},
    "class_type": "CLIPTextEncode",
    "_meta": {"title": "Pozitif İstem"}
  },
  "7": {
    "inputs": {"text": "*ninput*", "clip": ["38", 1]},
    "class_type": "CLIPTextEncode",
    "_meta": {"title": "Negatif İstem"}
  },
  "8": {
    "inputs": {"samples": ["3", 0], "vae": ["4", 2]},
    "class_type": "VAEDecode",
    "_meta": {"title": "VAE Kod Çözme"}
  },
  "9": {
    "inputs": {"filename_prefix": "*prefix*", "images": ["70", 0]},
    "class_type": "SaveImage",
    "_meta": {"title": "Görüntüyü Kaydet"}
  },
  "35": {
    "inputs": {"lora_name": "*lora*", "strength_model": "*lorawt*", "strength_clip": 1, "model": ["4", 0], "clip": ["4", 1]},
    "class_type": "LoraLoader",
    "_meta": {"title": "LoRA - Slot 1"}
  },
  "36": {
    "inputs": {"lora_name": "*lora2*", "strength_model": "*lorawt2*", "strength_clip": 1, "model": ["35", 0], "clip": ["35", 1]},
    "class_type": "LoraLoader",
    "_meta": {"title": "LoRA - Slot 2"}
  },
  "37": {
    "inputs": {"lora_name": "*lora3*", "strength_model": "*lorawt3*", "strength_clip": 1, "model": ["36", 0], "clip": ["36", 1]},
    "class_type": "LoraLoader",
    "_meta": {"title": "LoRA - Slot 3"}
  },
  "38": {
    "inputs": {"lora_name": "*lora4*", "strength_model": "*lorawt4*", "strength_clip": 1, "model": ["37", 0], "clip": ["37", 1]},
    "class_type": "LoraLoader",
    "_meta": {"title": "LoRA - Slot 4"}
  },
  "64": {
    "inputs": {"image": "*refimage*"},
    "class_type": "LoadImage",
    "_meta": {"title": "Referans Yüz (eşleşme kartı portresi)"}
  },
  "70": {
    "inputs": {
      "enabled": true,
      "input_image": ["8", 0],
      "source_image": ["64", 0],
      "swap_model": "inswapper_128.onnx",
      "facedetection": "retinaface_resnet50",
      "face_restore_model": "GFPGANv1.4.pth",
      "face_restore_visibility": 1,
      "codeformer_weight": 0.5,
      "detect_gender_input": "no",
      "detect_gender_source": "no",
      "input_faces_index": "0",
      "source_faces_index": "0",
      "console_log_level": 1
    },
    "class_type": "ReActorFaceSwap",
    "_meta": {"title": "ReActor Face Swap (kimlik = referans yüz)"}
  }
}
